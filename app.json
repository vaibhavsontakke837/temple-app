{
  "expo": {
    "name": "श्री समर्थ धोंडुतात्या प्रसन्ना",
    "slug": "temple-app",
    "version": "1.0.0",
    "description": "Official app for Shri Samarth Dhondutatya Maharaj Temple, Viral. Access temple information, events, aarti timings, and spiritual content.",
    "privacy": "https://vaibhavsontakke837.github.io/temple-app-privacy/",
    "orientation": "portrait",
    "icon": "./assets/gallery/icon.png",
    "scheme": "templeapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/gallery/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/gallery/android-icon-foreground.png",
        "backgroundImage": "./assets/gallery/android-icon-background.png",
        "monochromeImage": "./assets/gallery/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.templeapp.viral",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "versionCode": 1
    },
    "web": {
      "output": "static",
      "favicon": "./assets/gallery/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4b469e7b-2601-4939-a8f1-f21d72271a60"
      }
    },
    "owner": "v_s"
  }
}
