{
  "expo": {
    "name": "temple-app",
    "slug": "temple-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/gallery/icon.png",
    "scheme": "templeapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/gallery/android-icon-foreground.png",
        "backgroundImage": "./assets/gallery/android-icon-background.png",
        "monochromeImage": "./assets/gallery/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.templeapp"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/gallery/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/gallery/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-localization",
      "expo-web-browser",
      [
        "expo-font",
        {
          "fonts": [
            "https://fonts.googleapis.com/css2?family=Noto+Sans+Devanagari:wght@400;500;600;700&display=swap"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d11274c3-4a7a-4a51-a081-1a1cbf37f593"
      }
    },
    "owner": "sontakke_vaibhav837"
  }
}
